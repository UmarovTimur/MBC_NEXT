# ─── App ──────────────────────────────────────────────────────────────────────

# Language code — must match a key in shared/config/bibles/ and shared/config/dictionary/
# Available: uz | az
APP_LANG=uz

# NODE environment
# Available: development | production
NODE_ENV=development

# ─── Routing ──────────────────────────────────────────────────────────────────

# Subdirectory path (without slashes). Leave empty if deployed to root.
# Example: BASE_PATH=mcdonald → site served at https://example.com/mcdonald/
BASE_PATH=

# Full domain URL with trailing slash
DOMAIN=https://example.com/

# ─── Debug ────────────────────────────────────────────────────────────────────

# Set to 'true' to enable build-time debug output
DEBUG_BUILD=false
